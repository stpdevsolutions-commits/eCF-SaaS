# ==============================================================
# eCF-SaaS - Variables de entorno
# Copia este archivo a .env y ajusta los valores.
# ==============================================================

# Entorno: development | production | test (default: development)
NODE_ENV=development

# Puerto HTTP de la API (default: 3000)
APP_PORT=3000

# --- Base de datos (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ecf_saas

# --- Autenticación (JWT) ---
# REQUERIDO en producción (NODE_ENV=production): la app no arranca si falta.
# En producción debe tener al menos 32 caracteres.
# En desarrollo, si falta, se usa un fallback inseguro con warning en consola.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Expiración del token (default: 24h)
JWT_EXPIRATION=24h

# --- CORS ---
# Orígenes permitidos, separados por comas (default: http://localhost:3005,
# donde corre el frontend Next.js en dev).
# Ejemplo producción: CORS_ORIGIN=https://app.midominio.com,https://admin.midominio.com
CORS_ORIGIN=http://localhost:3005
