# ==============================================================
# eCF-SaaS - Variables de entorno
# Copia este archivo a .env y ajusta los valores.
# ==============================================================

# Entorno: development | production | test (default: development)
NODE_ENV=development

# Puerto HTTP de la API (default: 3000)
APP_PORT=3000

# --- Base de datos (PostgreSQL) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ecf_saas

# --- Autenticación (JWT) ---
# REQUERIDO en producción (NODE_ENV=production): la app no arranca si falta.
# En producción debe tener al menos 32 caracteres.
# En desarrollo, si falta, se usa un fallback inseguro con warning en consola.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Expiración del token (default: 24h)
JWT_EXPIRATION=24h

# --- CORS ---
# Orígenes permitidos, separados por comas (default: http://localhost:3005,
# donde corre el frontend Next.js en dev).
# Ejemplo producción: CORS_ORIGIN=https://app.midominio.com,https://admin.midominio.com
CORS_ORIGIN=http://localhost:3005

# --- Integración DGII (e-CF real) ---
# Mientras estas variables no estén configuradas, la app sigue funcionando en
# modo mock (firma con certificado autofirmado de desarrollo, DGII simulada).
# En cuanto llegue el certificado .p12 de un PSC (INDOTEL) + credenciales
# TesteCF, basta con completarlas aquí: no se requieren cambios de código.

# Ambiente DGII: TesteCF (pruebas) | CerteCF (certificación) | eCF (producción)
DGII_ENVIRONMENT=TesteCF

# Certificado .p12 del emisor, codificado en Base64 (una sola línea).
# Genera el valor con: node -e "console.log(require('fs').readFileSync('cert.p12').toString('base64'))"
DGII_CERT_P12_BASE64=

# Contraseña del certificado .p12
DGII_CERT_PASSPHRASE=
